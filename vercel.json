{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/backend/(.*)",
      "destination": "/backend/main.py"
    },
    {
      "source": "/api/backend",
      "destination": "/backend/main.py"
    }
  ]
}
